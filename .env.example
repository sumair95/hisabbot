# ============================================================
# Kirana Bookkeeper — Environment Configuration
# Copy this file to `.env` and fill in the real values.
# Never commit the real `.env` — it is git-ignored.
# ============================================================

# ---------- App ----------
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO
PORT=8000

# ---------- WhatsApp (Meta Cloud API) ----------
# From: https://developers.facebook.com/apps/<your-app>/whatsapp-business/wa-dev-console/
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
# A random string you pick; enter the same value when configuring the webhook on Meta's side.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-to-a-random-string
# Optional: use to validate X-Hub-Signature-256 header from Meta
WHATSAPP_APP_SECRET=

# ---------- Supabase / Postgres ----------
# The full Postgres connection string from Supabase → Project Settings → Database → Connection String
# Use the "Session mode" (port 5432) connection string, not the pooler, for asyncpg.
SUPABASE_DB_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
# Optional: Supabase URL + anon/service keys if you later use Supabase client SDK
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- LLM: Anthropic (primary, for extraction & replies) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---------- STT: OpenAI Whisper (voice notes) ----------
OPENAI_API_KEY=
OPENAI_WHISPER_MODEL=whisper-1

# ---------- Optional fallbacks ----------
# If ANTHROPIC fails, we can fall back to OpenAI for extraction
FALLBACK_OPENAI_MODEL=gpt-4o-mini

# ---------- Business logic ----------
DEFAULT_TIMEZONE=Asia/Karachi
DAILY_SUMMARY_HOUR=21        # 9pm local time
MAX_VOICE_NOTES_PER_DAY=200  # rate limit per shopkeeper
